---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
}

const {
  title,
  description = 'konrad seifert — ai diplomacy, community building, djing, and radically better futures.',
  ogImage = 'https://konrads.link/og-image.png',
  bodyClass = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={Astro.url.href}>
  <meta property="og:image" content={ogImage}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="alternate" type="application/rss+xml" title="konrad seifert" href="/rss.xml">
  <slot name="head" />
</head>
<body class={bodyClass}>
  <slot />

  <!-- WIP notice popup -->
  <div id="wip-popup" style="
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease;
  ">
    <div style="
      background: #1a1a1a;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 12px;
      padding: 2rem 2.5rem;
      max-width: 420px;
      margin: 1rem;
      font-family: 'Inter', sans-serif;
      color: #e0e0e0;
      text-align: center;
    ">
      <p style="font-size: 1.1rem; font-weight: 500; margin: 0 0 0.75rem;">heads up</p>
      <p style="font-size: 0.95rem; line-height: 1.6; margin: 0 0 1.5rem; color: #aaa;">
        this site is currently under construction; some of the text is lazy slop — i'm aware and reasonably ashamed. nonetheless, the content is better than nothing already. i hope you enjoy! also, there may be one or two easter eggs hidden around.
      </p>
      <button id="wip-dismiss" style="
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e0e0e0;
        padding: 0.5rem 1.5rem;
        border-radius: 6px;
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        cursor: pointer;
        transition: border-color 0.2s;
      ">got it</button>
    </div>
  </div>
  <script is:inline>
    (function() {
      if (sessionStorage.getItem('wip-dismissed')) return;
      var popup = document.getElementById('wip-popup');
      popup.style.display = 'flex';
      requestAnimationFrame(function() { popup.style.opacity = '1'; });
      document.getElementById('wip-dismiss').addEventListener('click', function() {
        sessionStorage.setItem('wip-dismissed', '1');
        popup.style.opacity = '0';
        setTimeout(function() { popup.remove(); }, 300);
      });
    })();
  </script>

  <!-- GoatCounter — privacy-friendly analytics -->
  <script data-goatcounter="https://konrads.goatcounter.com/count"
          async src="//gc.zgo.at/count.js" is:inline></script>
</body>
</html>
